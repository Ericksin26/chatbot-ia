# OpenAI
OPENAI_API_KEY=tu-api-key-aqui

# Modelo
MODEL_NAME=gpt-3.5-turbo

# Parametros del modelo
MAX_TOKENS=200
TEMPERATURE=0.7

# Prompt del sistema
SYSTEM_PROMPT=Eres un asistente amigable, servicial y con conocimientos en programacion, inteligencia artificial, matematicas y tecnologia. Responde en español de forma clara y concisa.

# Historial
SAVE_HISTORY=true
MAX_HISTORY=50
